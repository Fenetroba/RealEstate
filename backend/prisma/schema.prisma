// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// 0. users
//    Platform user accounts (email + password auth)
// ─────────────────────────────────────────────
model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String
  first_name       String
  last_name        String
  role             UserRole  @default(USER)
  isEmailVerified  Boolean   @default(false)
  isVerified       Boolean   @default(false)
  walletAddress    String?   @unique
  phone            String?
  location         String?
  avatar           String?

  // Refresh tokens stored as JSON array (simple multi-device support)
  refreshTokens    String[]  @default([])

  kycSubmissions   KycSubmission[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([email])
}

enum UserRole {
  USER
  ADMIN
}

// ─────────────────────────────────────────────
// 1. properties
//    One row per minted property.
//    All searchable fields stored as real columns
//    so you can filter/sort without touching the chain.
// ─────────────────────────────────────────────
model Property {
  id                String    @id @default(uuid())
  tokenId           String    @unique               // NFT token ID (as string to avoid int overflow)
  ownerWallet       String                          // current owner's wallet address
  status            PropertyStatus @default(PENDING) // PENDING | MINTED | DECLINED

  // Land title number — must be unique across the registry
  titleNumber       String?   @unique               // government-issued land title number

  // Property details (mirrors your contract struct)
  name              String
  location          String         // human-readable address / area
  propertyType      String

  // ── Geographic location (from Google Maps selection) ──────────────────────
  address           String?        // full formatted address from Google
  latitude          Float?         // WGS-84 decimal degrees
  longitude         Float?         // WGS-84 decimal degrees
  elevation         Float?         // meters above sea level (Google Elevation API)
  placeId           String?        // Google Maps place_id for future API calls
  bedrooms          Int       @default(0)
  bathrooms         Int       @default(0)
  squareFeet    Int       @default(0)
  parking       Int       @default(0)
  floors        Int       @default(0)
  yearBuilt     Int       @default(0)
  price         String                       // stored as string (wei value / ETH amount for sale)
  rentPrice     String?                      // monthly rent in ETH (null if not for rent)
  isForSale     Boolean   @default(false)    // listed for sale on marketplace
  isForRent     Boolean   @default(false)    // listed for rent on marketplace
  description       String?

  // Hashes (latest approved version — for quick lookup)
  metadataHash      String?   @db.VarChar(64)       // SHA-256 hex of the metadata JSON
  imagesRootHash    String?   @db.VarChar(64)       // Merkle root of all image hashes
  documentsRootHash String?   @db.VarChar(64)       // Merkle root of all document hashes
  chainHash         String?   @db.VarChar(64)       // the hash stored on-chain (matches metadataHash on approval)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  documents         Document[]
  metadataVersions  MetadataVersion[]
  requests          Request[]
}

// ─────────────────────────────────────────────
// 2. documents
//    One row per uploaded file.
//    Raw file bytes stored as Bytes (PostgreSQL bytea).
//    Old versions are NEVER deleted — full audit trail.
// ─────────────────────────────────────────────
model Document {
  id          String      @id @default(uuid())
  propertyId  String
  property    Property    @relation(fields: [propertyId], references: [id])

  fileData    Bytes                               // raw file bytes (bytea)
  sha256Hash  String      @db.VarChar(64)         // hex hash of fileData
  fileName    String                              // original file name
  mimeType    String                              // e.g. "application/pdf", "image/jpeg"
  fileType    DocumentFileType                    // IMAGE | DOCUMENT
  docType     String                              // "deed" | "survey" | "id" | "photo" etc.
  versionNo   Int         @default(1)             // increments on metadata updates
  sizeBytes   Int                                 // file size in bytes

  uploadedBy  String                              // wallet address of uploader
  isDuplicate Boolean     @default(false)         // true if same hash exists elsewhere
  createdAt   DateTime    @default(now())

  @@index([propertyId])
  @@index([sha256Hash])
}

// ─────────────────────────────────────────────
// 3. metadata_versions
//    Every approved change to a property's metadata
//    gets a new row. Mirrors the version history on-chain.
// ─────────────────────────────────────────────
model MetadataVersion {
  id                String    @id @default(uuid())
  propertyId        String
  property          Property  @relation(fields: [propertyId], references: [id])

  versionNo         Int                           // 1, 2, 3 ...
  metadataHash      String    @db.VarChar(64)     // SHA-256 of the metadata JSON at this version
  imagesRootHash    String    @db.VarChar(64)     // Merkle root of images at this version
  documentsRootHash String    @db.VarChar(64)     // Merkle root of documents at this version
  metadataSnapshot  Json                          // full metadata JSON saved for reference

  approvedAt        DateTime  @default(now())
  approvedBy        String                        // gov't wallet address

  @@unique([propertyId, versionNo])
  @@index([propertyId])
}

// ─────────────────────────────────────────────
// 4. requests
//    Every citizen-initiated action (mint or update).
//    Gov't reviews these and approves or declines.
// ─────────────────────────────────────────────
model Request {
  id                String        @id @default(uuid())
  propertyId        String?                         // null for initial mint requests (no token yet)
  property          Property?     @relation(fields: [propertyId], references: [id])

  type              RequestType                     // MINT | UPDATE
  status            RequestStatus @default(PENDING) // PENDING | APPROVED | DECLINED

  // Hashes proposed in this request (what will go on-chain if approved)
  metadataHash      String        @db.VarChar(64)
  imagesRootHash    String        @db.VarChar(64)
  documentsRootHash String        @db.VarChar(64)

  // Snapshot of metadata submitted with this request
  metadataSnapshot  Json

  // Wallets
  submittedBy       String                          // citizen wallet
  reviewedBy        String?                         // gov't wallet (set on approval/decline)

  // Linked document IDs (the files submitted with this request)
  documentIds       String[]                        // array of Document.id

  // Timestamps
  submittedAt       DateTime      @default(now())
  reviewedAt        DateTime?

  // Optional: reason for decline
  declineReason     String?

  // On-chain request ID (index in the contract's requests mapping)
  // Set by confirmRequest after the user's MetaMask tx is confirmed.
  onChainRequestId  Int?

  @@index([status])
  @@index([submittedBy])
}

// ─────────────────────────────────────────────
// 5. kyc_submissions
//    One row per user KYC attempt.
// ─────────────────────────────────────────────
model KycSubmission {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])

  status         KycStatus     @default(PENDING)
  submittedAt    DateTime      @default(now())
  reviewedAt     DateTime?
  reviewedBy     String?       // admin user id
  rejectReason   String?

  documents      KycDocument[]

  @@index([userId])
  @@index([status])
}

model KycDocument {
  id             String        @id @default(uuid())
  submissionId   String
  submission     KycSubmission @relation(fields: [submissionId], references: [id])

  kind           KycDocKind                // ID_FRONT | ID_BACK | SELFIE
  fileData       Bytes                     // raw bytes stored in DB
  sha256Hash     String        @db.VarChar(64)
  fileName       String
  mimeType       String
  sizeBytes      Int

  createdAt      DateTime      @default(now())

  @@index([submissionId])
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycDocKind {
  ID_FRONT
  ID_BACK
  SELFIE
}

enum PropertyStatus {
  PENDING
  MINTED
  DECLINED
}

enum DocumentFileType {
  IMAGE
  DOCUMENT
}

enum RequestType {
  MINT
  UPDATE
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
}

// ─────────────────────────────────────────────
// 6. notifications
//    In-app notifications for users.
// ─────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?          // optional deep-link (e.g. /dashboard/my-requests)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum NotificationType {
  SYSTEM
  REQUEST_APPROVED
  REQUEST_DECLINED
  KYC_APPROVED
  KYC_REJECTED
  PROPERTY_VERIFIED
}


//    User-submitted support requests with chat thread.
// ─────────────────────────────────────────────
model SupportTicket {
  id          String          @id @default(uuid())
  userId      String?         // null if unauthenticated guest
  guestEmail  String?         // for unauthenticated users
  guestName   String?
  subject     String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(NORMAL)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  messages    SupportMessage[]

  @@index([status])
  @@index([userId])
}

model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body      String
  isAdmin   Boolean       @default(false)   // true = sent by admin
  senderName String?                        // display name
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}
